generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id       String @id @default(cuid())
  username String @unique
  password String
  role     String @default("USER")
currentSessionId String? // 👈 ВОТ ЭТО

  createdAt DateTime @default(now())
}
